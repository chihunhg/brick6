declare(strict_types=1);

/**
 * 正式機 .env 路徑設定（範例檔）
 *
 * 使用方式：
 * 1. 複製本檔為同目錄的 env.path.php（勿提交版本庫）
 * 2. return 的目錄必須含有 .env 檔案
 *
 * 常見佈局：
 * - brick6 在 private 內、.env 與 brick6 同層：return dirname(__DIR__) . '/..';
 * - brick6 在 httpdocs、.env 在 private：return dirname(__DIR__) . '/../private';
 * - 絕對路徑：return '/var/www/vhosts/example.com/private';
 */

// tsg5：/private/.env 與 /private/brick6/ 同層
return dirname(__DIR__) . '/..';
