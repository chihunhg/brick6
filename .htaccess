# =========== Header ===========
<IfModule mod_headers.c>
    Header always unset X-Powered-By
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always edit Set-Cookie (.*) "$1; HttpOnly; Secure; SameSite=Lax"
    # HSTS：Plesk/nginx 主機（如 tsg5.com.tw）通常已在伺服器層送出，勿在此重複（Observatory 會判無法辨識）
    # 僅 Apache 直連、且主機未送 HSTS 時，取消下行註解，並設 .env APP_ENABLE_HSTS=0
    # Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains" env=HTTPS
    # CSP / X-Frame-Options 改由 PHP 依請求動態注入（見 _inc.php → send_security_headers）
    Header set X-XSS-Protection "1; mode=block"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), fullscreen=(self), accelerometer=(), gyroscope=(), magnetometer=(), usb=(), payment=()"
    # 上傳圖片／靜態資源：瀏覽器長期快取（Upload/、images/、css/、js/）
    <FilesMatch "\.(?i:jpe?g|png|gif|webp|svg|ico|woff2?|css|js|pdf|mp4|zip)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>
# ==============================

Options -Indexes
<IfModule mod_rewrite.c>
RewriteEngine On

# 阻擋開發／建置設定檔對外存取（弱掃：composer、package.json、.travis.yml 等）
RewriteRule (^|/)(composer\.(json|lock)|package(-lock)?\.json|\.travis\.yml|\.env)$ - [F,L]

#RewriteCond %{SERVER_PORT} !^443$
#RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

#***_inc.php 有設定，若未傳 $this_lang ，則 $this_lang 預設=1***
#this_lang 1=繁中 2=英文

#切換語系
#RewriteRule ^$ index.php?this_lang=1 [L]
RewriteRule ^en/$ index.php?this_lang=2 [L]
RewriteRule ^en$ index.php?this_lang=2 [L]

# 友好 URL 慣例（Class 無值時不帶參數）：
#   module.htm              → 列表（無 Class1/2/3）
#   module{N}.htm           → Class1=N
#   product{A}-{B}.htm      → Class1=A、Class2=B
#   product{A}-{B}-{C}.htm  → Class1=A、Class2=B、Class3=C
# 分類編號用 [0-9]+，避免 module0.htm 或空 Class 參數。

#專欄主題
RewriteRule ^paper\.htm$ paper.php?this_lang=1 [L]
RewriteRule ^paper([0-9]+)\.htm$ paper.php?this_lang=1&Class1=$1 [L]
RewriteRule ^paper-detail([0-9]+)\.htm$ paper-detail.php?this_lang=1&PKey=$1 [L]
#英文
RewriteRule ^en/paper\.htm$ paper.php?this_lang=2 [L]
RewriteRule ^en/paper([0-9]+)\.htm$ paper.php?this_lang=2&Class1=$1 [L]
RewriteRule ^en/paper-detail([0-9]+)\.htm$ paper-detail.php?this_lang=2&PKey=$1 [L]

#最新消息
RewriteRule ^news\.htm$ news.php?this_lang=1 [L]
RewriteRule ^news([0-9]+)\.htm$ news.php?this_lang=1&Class1=$1 [L]
RewriteRule ^news-detail([0-9]+)\.htm$ news-detail.php?this_lang=1&PKey=$1 [L]
#英文
RewriteRule ^en/news\.htm$ news.php?this_lang=2 [L]
RewriteRule ^en/news([0-9]+)\.htm$ news.php?this_lang=2&Class1=$1 [L]
RewriteRule ^en/news-detail([0-9]+)\.htm$ news-detail.php?this_lang=2&PKey=$1 [L]

#關於我們
RewriteRule ^company\.htm$ company.php?this_lang=1 [L]
RewriteRule ^company([0-9]+)\.htm$ company.php?this_lang=1&PKey=$1 [L]
#英文
RewriteRule ^en/company\.htm$ company.php?this_lang=2 [L]
RewriteRule ^en/company([0-9]+)\.htm$ company.php?this_lang=2&PKey=$1 [L]

#關於我們
RewriteRule ^questionnaire\.htm$ questionnaire.php?this_lang=1 [L]
RewriteRule ^questionnaire([0-9]+)\.htm$ questionnaire.php?this_lang=1&PKey=$1 [L]
#英文
RewriteRule ^en/questionnaire\.htm$ questionnaire.php?this_lang=2 [L]
RewriteRule ^en/questionnaire([0-9]+)\.htm$ questionnaire.php?this_lang=2&PKey=$1 [L]

#檔案下載
RewriteRule ^download\.htm$ download.php?this_lang=1 [L]
RewriteRule ^download([0-9]+)\.htm$ download.php?this_lang=1&Class1=$1 [L]
#英文
RewriteRule ^en/download\.htm$ download.php?this_lang=2 [L]
RewriteRule ^en/download([0-9]+)\.htm$ download.php?this_lang=2&Class1=$1 [L]

#相關網站
RewriteRule ^weblink\.htm$ weblink.php?this_lang=1 [L]
RewriteRule ^weblink([0-9]+)\.htm$ weblink.php?this_lang=1&Class1=$1 [L]
#英文
RewriteRule ^en/weblink\.htm$ weblink.php?this_lang=2 [L]
RewriteRule ^en/weblink([0-9]+)\.htm$ weblink.php?this_lang=2&Class1=$1 [L]

#相簿
RewriteRule ^album\.htm$ album.php?this_lang=1 [L]
RewriteRule ^album([0-9]+)\.htm$ album.php?this_lang=1&Class1=$1 [L]
RewriteRule ^album-detail([0-9]+)\.htm$ album-detail.php?this_lang=1&PKey=$1 [L]
#英文
RewriteRule ^en/album\.htm$ album.php?this_lang=2 [L]
RewriteRule ^en/album([0-9]+)\.htm$ album.php?this_lang=2&Class1=$1 [L]
RewriteRule ^en/album-detail([0-9]+)\.htm$ album-detail.php?this_lang=2&PKey=$1 [L]

#工業產品（三層分類：僅有值的層級才出現在 URL）
RewriteRule ^product\.htm$ product.php?this_lang=1 [L]
RewriteRule ^product([0-9]+)\.htm$ product.php?this_lang=1&Class1=$1 [L]
RewriteRule ^product([0-9]+)-([0-9]+)\.htm$ product.php?this_lang=1&Class1=$1&Class2=$2 [L]
RewriteRule ^product([0-9]+)-([0-9]+)-([0-9]+)\.htm$ product.php?this_lang=1&Class1=$1&Class2=$2&Class3=$3 [L]
RewriteRule ^product-detail([0-9]+)\.htm$ product-detail.php?this_lang=1&PKey=$1 [L]
#英文
RewriteRule ^en/product\.htm$ product.php?this_lang=2 [L]
RewriteRule ^en/product([0-9]+)\.htm$ product.php?this_lang=2&Class1=$1 [L]
RewriteRule ^en/product([0-9]+)-([0-9]+)\.htm$ product.php?this_lang=2&Class1=$1&Class2=$2 [L]
RewriteRule ^en/product([0-9]+)-([0-9]+)-([0-9]+)\.htm$ product.php?this_lang=2&Class1=$1&Class2=$2&Class3=$3 [L]
RewriteRule ^en/product-detail([0-9]+)\.htm$ product-detail.php?this_lang=2&PKey=$1 [L]

#投資人專區
RewriteRule ^investor\.htm$ investor.php?this_lang=1 [L]
RewriteRule ^investor([0-9]+)\.htm$ investor.php?this_lang=1&Class1=$1 [L]
RewriteRule ^investor-detail([0-9]+)\.htm$ investor-detail.php?this_lang=1&PKey=$1 [L]
#英文
RewriteRule ^en/investor\.htm$ investor.php?this_lang=2 [L]
RewriteRule ^en/investor([0-9]+)\.htm$ investor.php?this_lang=2&Class1=$1 [L]
RewriteRule ^en/investor-detail([0-9]+)\.htm$ investor-detail.php?this_lang=2&PKey=$1 [L]

#相關問題
RewriteRule ^faq\.htm$ faq.php?this_lang=1 [L]
RewriteRule ^faq([0-9]+)\.htm$ faq.php?this_lang=1&Class1=$1 [L]
# FAQ Demo（Day 7 onboarding）
RewriteRule ^faqdemo\.htm$ faqdemo.php?this_lang=1 [L]
RewriteRule ^faqdemo([0-9]+)\.htm$ faqdemo.php?this_lang=1&Class1=$1 [L]
#英文
RewriteRule ^en/faq\.htm$ faq.php?this_lang=2 [L]
RewriteRule ^en/faq([0-9]+)\.htm$ faq.php?this_lang=2&Class1=$1 [L]
RewriteRule ^en/faqdemo\.htm$ faqdemo.php?this_lang=2 [L]
RewriteRule ^en/faqdemo([0-9]+)\.htm$ faqdemo.php?this_lang=2&Class1=$1 [L]

RewriteRule ^(.*_bak.*)$ / [R=301,NC]
RewriteRule ^(.*-bak.*)$ / [R=301,NC]
RewriteRule ^(.*.php_.*)$ / [R=301,NC]
RewriteRule ^(.*.php-.*)$ / [R=301,NC]

RewriteCond %{REQUEST_URI} !^[\/manage\/]+$
RewriteRule ^en/(.*)\.htm$ $1.php?this_lang=2 [L]
RewriteRule ^(.*)\.htm$ $1.php?this_lang=1 [L]

</IfModule>

#ErrorDocument 404 https://www.xxxxxx.com/

